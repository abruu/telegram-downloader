# ================================================================
#  Telegram Media Bot — Configuration
#  Copy this file to .env and fill in your values.
#  Run ./setup.sh for an interactive setup wizard.
# ================================================================


# ── Telegram Bot (REQUIRED) ─────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# Get from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Your personal Telegram user ID — get from @userinfobot
TELEGRAM_OWNER_ID=


# ── Metadata APIs (OPTIONAL but recommended) ────────────────────
# Free key: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Free key: https://thetvdb.com/api-information
TVDB_API_KEY=


# ── Storage Paths ───────────────────────────────────────────────
# Where finished media is stored (Jellyfin/Plex/Emby library root)
MEDIA_PATH=/mnt/media

# Temporary download staging folder
DOWNLOAD_PATH=/mnt/media/downloads

# Telethon session file path (no extension)
SESSION_PATH=./data/userbot_session

# SQLite databases and user list
REQUEST_LOG_DB=./data/request_log.db
MEDIA_DB=./data/media_library.db
USERS_FILE=./data/users.json

# Log file
LOG_FILE=./logs/bot.log


# ── Known Movie Channels (OPTIONAL) ─────────────────────────────
# Comma-separated list of Telegram channel IDs to treat as movie sources
# Example: -1001234567890,-1009876543210
KNOWN_MOVIE_CHANNELS=


# ── VPN (OPTIONAL) ──────────────────────────────────────────────
# Set VPN_ENABLED=true to route all traffic through OpenVPN.
# Requires 'openvpn' to be installed on the host system.
#
# VPN_ENABLED=false
#
# Path to your .ovpn configuration file (required when VPN_ENABLED=true)
# VPN_CONFIG_FILE=/etc/openvpn/client.ovpn
#
# Optional: path to a credentials file (username on line 1, password on line 2)
# Leave empty if the .ovpn file embeds credentials or uses certificate auth.
# VPN_AUTH_FILE=/etc/openvpn/auth.txt
#
# Auto-reconnect when the tunnel drops (default: true)
# VPN_RECONNECT=true
#
# Max consecutive reconnect attempts before giving up (0 = unlimited)
# VPN_MAX_RETRIES=5


# ── Performance Tuning (OPTIONAL — defaults shown) ──────────────
PARALLEL_CONNECTIONS=4
CHUNK_SIZE=524288
MAX_QUEUE=20
MAX_QUEUE_PER_USER=3
MAX_RETRIES=20
DISK_HEADROOM=209715200
HISTORY_MAX=50
